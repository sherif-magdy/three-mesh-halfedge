{
  "name": "@sherifmagdy/three-mesh-halfedge",
  "description": "A typescript implementation of the Halfedge structure for three.js geometries.",
  "keywords": [
    "threejs",
    "geometry",
    "mesh",
    "csg",
    "halfedge"
  ],
  "version": "2.4.0",
  "author": {
    "name": "Axel Antoine",
    "email": "ax.antoine@gmail.com",
    "url": "https://axantoine.com"
  },
  "license": "MIT",
  "branch": "main",
  "type": "module",
  "main": "build/index.cjs",
  "module": "build/index.esm.js",
  "types": "build/types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./build/types/index.d.ts",
      "import": "./build/index.esm.js",
      "require": "./build/index.cjs",
      "default": "./build/index.esm.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "build"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sherif-magdy/three-mesh-halfedge.git"
  },
  "homepage": "https://github.com/sherif-magdy/three-mesh-halfedge#readme",
  "scripts": {
    "build": "rollup -c",
    "build-examples": "rollup -c --environment examples",
    "build-doc": "typedoc src/index.ts",
    "dev": "rollup -cw",
    "dev-examples": "rollup -cw --environment examples",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src examples tests",
    "lint-examples": "eslint examples",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "three": ">= 0.123.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/dat.gui": "^0.7.13",
    "@types/three": "^0.184.1",
    "@types/throttle-debounce": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "dat.gui": "^0.7.9",
    "eslint": "^10.4.1",
    "rollup": "^4.61.1",
    "rollup-plugin-generate-html-template": "^1.7.0",
    "three": "^0.184.0",
    "throttle-debounce": "^5.0.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
